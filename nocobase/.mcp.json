{
  "mcpServers": {
    "nocobase": {
      "command": "npx",
      "args": [
        "-y",
        "@nocobase/mcp-server"
      ],
      "env": {
        "NOCOBASE_URL": "${NOCOBASE_URL}",
        "NOCOBASE_EMAIL": "${NOCOBASE_EMAIL}",
        "NOCOBASE_PASSWORD": "${NOCOBASE_PASSWORD}"
      }
    }
  }
}